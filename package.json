{
  "name": "vite-plus-inspector",
  "version": "0.1.0",
  "description": "Visualize your vite-plus configuration",
  "keywords": [
    "cli",
    "config",
    "inspector",
    "oxlint",
    "visualizer",
    "vite",
    "vite-plus"
  ],
  "homepage": "https://github.com/k35o/vite-plus-inspector#readme",
  "bugs": "https://github.com/k35o/vite-plus-inspector/issues",
  "license": "MIT",
  "author": "k8o (https://github.com/k35o)",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/k35o/vite-plus-inspector.git"
  },
  "bin": {
    "vp-inspect": "./dist/cli.mjs"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE",
    "CHANGELOG.md"
  ],
  "type": "module",
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "scripts": {
    "build": "vp pack",
    "test": "vp test",
    "lint": "vp lint",
    "fmt": "vp fmt",
    "check": "vp check",
    "check:write": "vp check --fix",
    "typecheck": "tsc --noEmit",
    "changeset": "changeset",
    "version": "changeset version",
    "release": "pnpm build && changeset publish",
    "prepublishOnly": "pnpm build",
    "prepare": "vp config"
  },
  "dependencies": {
    "cac": "7.0.0",
    "jiti": "2.7.0"
  },
  "devDependencies": {
    "@changesets/changelog-github": "0.7.0",
    "@changesets/cli": "2.31.0",
    "@k8o/oxc-config": "0.1.3",
    "@types/node": "24.13.2",
    "typescript": "6.0.3",
    "vite-plus": "0.1.23"
  },
  "engines": {
    "node": ">=24.13.0"
  },
  "packageManager": "pnpm@11.5.1"
}
